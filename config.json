  "authFlow": {
    "login": {
      "action": "verifyPassword",
      "input": {
        "email": "string",
        "password": "string",
        "deviceFingerprint": "string",
        "ipAddress": "string | optional"
      },
      "successResponse": {
        "valid": true,
        "mustChangePassword": false,
        "clientName": "string | null",
        "sessionToken": "string(64)",
        "expiresAt": "ISO_DATE"
      },
      "firstLoginResponse": {
        "valid": false,
        "firstLogin": true,
        "emailSent": true,
        "message": "string"
      },
      "newDeviceResponse": {
        "valid": false,
        "requiresOtp": true,
        "emailSent": true,
        "message": "string"
      },
      "lockedResponse": {
        "valid": false,
        "locked": true,
        "lockedUntil": "ISO_DATE",
        "message": "string"
      },
      "invalidPasswordResponse": {
        "valid": false,
        "message": "string",
        "remainingAttempts": "number",
        "locked": false
      }
    },
    "otpVerification": {
      "action": "verifyOtp",
      "input": {
        "email": "string",
        "otpCode": "string(6)",
        "deviceFingerprint": "string",
        "deviceName": "string | optional",
        "trustDevice": "boolean"
      },
      "successResponse": {
        "valid": true,
        "mustChangePassword": false,
        "clientName": "string | null",
        "sessionToken": "string(64)",
        "expiresAt": "ISO_DATE"
      },
      "expiredResponse": {
        "valid": false,
        "expired": true,
        "message": "string"
      },
      "invalidResponse": {
        "valid": false,
        "message": "string",
        "remainingAttempts": "number | optional"
      }
    },
    "otpResend": {
      "action": "resendOtp",
      "input": {
        "email": "string",
        "deviceFingerprint": "string"
      },
      "successResponse": {
        "success": true,
        "message": "Nowy kod został wysłany."
      },
      "cooldownResponse": {
        "success": false,
        "message": "Poczekaj XXs przed ponownym wysłaniem."
      }
    },
    "resetPassword": {
      "action": "resetPassword",
      "input": {
        "email": "string"
      },
      "response": {
        "success": true,
        "message": "Jeśli konto istnieje, nowe hasło zostanie wysłane na podany adres email."
      }
    },
    "changePassword": {
      "action": "changePassword",
      "input": {
        "email": "string",
        "password": "string",
        "newPassword": "string",
        "deviceFingerprint": "string | optional",
        "deviceName": "string | optional"
      },
      "successResponse": {
        "success": true,
        "message": "Hasło zostało zmienione"
      },
      "errorResponse": {
        "success": false,
        "message": "string"
      }
    }
  },
